# Team identity
TEAM_NAME=KMS_TEAM_02

# Odoo XML-RPC connection
ODOO_URL=http://localhost:8069
ODOO_DB=odoo17
ODOO_USER=admin
ODOO_PASSWORD=admin

# Vector database settings
CHROMA_PERSIST_DIR=./chroma_db
COLLECTION_NAME=kms_collection

# Embedding model: "sentence-transformers" (free/offline) or "openai"
EMBEDDING_PROVIDER=sentence-transformers

# LLM provider: "openai", "ollama", or "mock"
LLM_PROVIDER=ollama

# Required when LLM_PROVIDER=openai or EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Required when LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# RAG retrieval controls
RAG_MIN_RELEVANCE=0.0
RAG_MAX_CONTEXT_CHARS=6000
